FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
OUTPUT_DIR=output

TRANSCRIBE_BACKEND=auto
WHISPER_CPP_BIN=third_party/whisper.cpp/build-cuda/bin/whisper-cli.exe
WHISPER_CPP_MODEL_PATH=models/ggml-large-v3-turbo-q5_0.bin
LOCAL_WHISPER_DEVICE=auto
LOCAL_WHISPER_LANGUAGE=zh
LOCAL_WHISPER_PROMPT=
LOCAL_GPU_ONLY=true
GPU_IDLE_VRAM_THRESHOLD_MB=512
GPU_CLEANUP_WAIT_SECONDS=20
GPU_HEARTBEAT_SECONDS=10

SUMMARY_API_BASE_URL=
SUMMARY_API_KEY=
SUMMARY_API_MODEL=gpt-5.4

# Optional overrides for share-link browser tools.
# Leave these blank if `node` is already in PATH and Chrome is installed in the default location.
SHARE_LINK_NODE_BIN=
SHARE_LINK_NODE_PATH=
SHARE_LINK_CHROME_EXE=

CHUNK_MAX_MINUTES=3
CHUNK_GAP_SECONDS=12
